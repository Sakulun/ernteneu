# Schenck Disomat Opus — Netzwerk-Einstellungen
# IP-Adresse des Disomat Opus (im Terminal-Menü unter Ethernet/Netzwerk einsehen)
WAAGE_IP=192.168.1.50

# TCP-Port (im Disomat Opus Menü konfiguriert, Standard meist 8000)
WAAGE_PORT=8000

# MinProz-Abfragebefehl (SI = Stable/Instant, S = Stable, P = Print)
# Bei älteren Firmware-Versionen ggf. auf "S" ändern
POLL_CMD=SI

# Abfrageintervall in Millisekunden
POLL_MS=2000

# Supabase (vom Projekt fijfxmjtoexpuxxjqqbf)
SUPABASE_URL=https://fijfxmjtoexpuxxjqqbf.supabase.co
# Service-Role-Key aus Supabase Dashboard > Settings > API
SUPABASE_KEY=HIER_SERVICE_ROLE_KEY_EINTRAGEN
